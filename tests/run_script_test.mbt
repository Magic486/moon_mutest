///|
fn script_config(fail_fast : Bool) -> @moon_mutest.MutestConfig {
  {
    include_kinds: [],
    include_labels: [],
    line_start: None,
    line_end: None,
    max_mutants: None,
    commands: [{ phase: CheckPhase, command: "moon check", timeout_ms: 10 }],
    fail_fast,
    report_format: TextReport,
  }
}

///|
test "generates bash runner script from execution plan" {
  let plan = @moon_mutest.build_execution_plan(
    [@moon_mutest.source_file("a.mbt", "a == b")],
    script_config(true),
  )
  let script = @moon_mutest.generate_runner_script(plan, BashDialect)
  inspect(script.mutant_count, content="1")
  inspect(
    @moon_mutest.format_runner_script(script),
    content=(
      #|#!/usr/bin/env bash
      #|set -euo pipefail
      #|
      #|# Generated by moon-mutest.
      #|# Selection: all
      #|# Mutants: 1 of 1 planned executions
      #|
      #|echo 'moon-mutest baseline'
      #|echo '+ moon check'
      #|moon check
      #|
      #|# mutant #0 a.mbt:1:3 eq-to-ne
      #|# apply: a.mbt[2..4] `==` -> `!=`
      #|echo '+ moon check'
      #|moon check
      #|# restore: a.mbt[2..4] `!=` -> `==`
    ),
  )
}

///|
test "generates selected powershell runner script" {
  let plan = @moon_mutest.build_execution_plan(
    [@moon_mutest.source_file("a.mbt", "a == b && true")],
    script_config(false),
  )
  let script = @moon_mutest.generate_selected_runner_script(
    plan,
    FirstMutants(1),
    PowerShellDialect,
  )
  inspect(script.mutant_count, content="1")
  let text = @moon_mutest.format_runner_script(script)
  assert_true(text.contains("# Selection: first 1"))
  assert_true(text.contains("# Mutants: 1 of 3 planned executions"))
  assert_true(text.contains("Write-Host '+ moon check'"))
  assert_true(!text.contains("$LASTEXITCODE"))
}

///|
test "script dialect labels are stable" {
  inspect(@moon_mutest.shell_dialect_label(BashDialect), content="bash")
  inspect(
    @moon_mutest.shell_dialect_label(PowerShellDialect),
    content="powershell",
  )
}
